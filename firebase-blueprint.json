{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User's academic profile and progress",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "level": { "type": "number" },
        "xp": { "type": "number" },
        "rank": { "type": "string" },
        "badges": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "ChatSession": {
      "title": "Chat Session",
      "description": "A conversation session with Spyris",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "department": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "uid", "title", "department"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a chat session",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "sessionId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["text", "quiz", "flashcard", "video", "image"] },
        "metadata": { "type": "object" }
      },
      "required": ["id", "sessionId", "role", "content", "timestamp"]
    },
    "Project": {
      "title": "Academic Project",
      "description": "A project managed by the user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "status": { "type": "string", "enum": ["Planning", "In Progress", "Review", "Completed"] },
        "tasks": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "uid", "title", "status"]
    },
    "Mark": {
      "title": "Academic Mark",
      "description": "A mark received for a subject",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "subject": { "type": "string" },
        "value": { "type": "number" },
        "date": { "type": "string", "format": "date" }
      },
      "required": ["id", "uid", "subject", "value", "date"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/sessions/{sessionId}": {
      "schema": "ChatSession",
      "description": "Chat session documents"
    },
    "/sessions/{sessionId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a session"
    },
    "/projects/{projectId}": {
      "schema": "Project",
      "description": "Academic project documents"
    },
    "/marks/{markId}": {
      "schema": "Mark",
      "description": "Academic mark documents"
    }
  }
}
